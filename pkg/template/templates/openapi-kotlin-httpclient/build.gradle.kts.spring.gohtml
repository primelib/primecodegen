{{- /*gotype: github.com/primelib/primecodegen/pkg/openapi/openapigenerator.SupportOnceTemplate*/ -}}
{{- template "header-singleline" }}

plugins {
    `java-library`
    alias(libs.plugins.configuration)
    alias(libs.plugins.kotlin.jvm)
    alias(libs.plugins.kotlin.allopen)
    alias(libs.plugins.kotlin.spring)
}

projectConfiguration {
    language.set(me.philippheuer.projectcfg.domain.ProjectLanguage.KOTLIN)
    type.set(me.philippheuer.projectcfg.domain.ProjectType.LIBRARY)
{{- if .Metadata.ArtifactId }}
    artifactId.set("{{ .Metadata.ArtifactId }}-spring-boot-starter")
{{- end }}
}

dependencies {
    // library
    api(project(":core"))

    // spring
    api(platform(libs.spring.boot.bom))
    api(libs.spring.boot.starter)
    annotationProcessor(libs.spring.boot.autoconfiguration.processor)
    annotationProcessor(libs.spring.boot.configuration.processor)
}
